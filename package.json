{
  "name": "crypto-tools",
  "version": "0.0.1",
  "author": "Ben Noack",
  "description": "Coinbase CLI tools and shared TypeScript library utilities",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benjaminjnoack/crypto-tools.git"
  },
  "homepage": "https://github.com/benjaminjnoack/crypto-tools#readme",
  "bugs": {
    "url": "https://github.com/benjaminjnoack/crypto-tools/issues"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "cb": "./dist/cb/cli.js",
    "helper-env-check": "./dist/lib/bin/validate-env.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/lib/bin/validate-env.js && chmod +x dist/cb/cli.js",
    "clean": "rm -rf dist",
    "dev": "tsx src/cb/cli.ts",
    "lint": "eslint src test eslint.config.mjs vitest.config.ts",
    "lint:fix": "eslint src test eslint.config.mjs vitest.config.ts --fix",
    "major": "npm run release:check && npm version major && git push && git push --tags",
    "minor": "npm run release:check && npm version minor && git push && git push --tags",
    "pack:dry": "npm pack --dry-run",
    "patch": "npm run release:check && npm version patch && git push && git push --tags",
    "prepare": "npm run build",
    "prepack": "npm run clean && npm run build",
    "release:check": "npm run lint && npm run typecheck && npm run test && npm run pack:dry",
    "smoke:bin": "node dist/cb/cli.js --help",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json"
  },
  "keywords": [
    "Coinbase",
    "coinbase-advanced-trade",
    "cli",
    "command-line",
    "trading",
    "crypto",
    "library",
    "typescript"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.2.3",
    "@types/readline-sync": "^1.4.8",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "axios": "^1.13.5",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "env-paths": "^4.0.0",
    "jsonwebtoken": "^9.0.3",
    "readline-sync": "^1.4.10",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  }
}
